{
  "actorSpecification": 1,
  "name": "daft-property-scraper",
  "title": "Daft.ie Property Scraper",
  "description": "Scrapes property listings from Daft.ie based on search terms. Handles Cloudflare protection and extracts detailed property information including prices, locations, amenities, and media.",
  "version": "1.0",
  "meta": {
    "templateId": "typescript"
  },
  "input": "./input_schema.json",
  "dockerfile": "../Dockerfile",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "overview": {
          "title": "Overview",
          "transformation": {
            "fields": [
              "id",
              "title",
              "price",
              "bedrooms",
              "bathrooms",
              "propertyType",
              "location",
              "dates"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "id": {
                "label": "ID"
              },
              "title": {
                "label": "Title"
              },
              "price": {
                "label": "Price"
              },
              "bedrooms": {
                "label": "Beds"
              },
              "bathrooms": {
                "label": "Baths"
              },
              "propertyType": {
                "label": "Type"
              },
              "location": {
                "label": "Location"
              },
              "dates": {
                "label": "Dates"
              }
            }
          }
        }
      }
    }
  }
}
